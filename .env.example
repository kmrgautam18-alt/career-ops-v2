# ==========================================
# Career-Ops v2 — Environment Configuration
# ==========================================
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# Application
APP_NAME=Career-Ops
APP_VERSION=2.0.0
APP_ENV=development
DEBUG=false

# Database
DATABASE_URL=sqlite:///./data/careerops.db
# PostgreSQL (production)
# DATABASE_URL=postgresql://careerops:changeme@localhost:5432/careerops
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
CORS_ALLOW_CREDENTIALS=true

# JWT Security
SECRET_KEY=change-this-secret-key-to-a-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Baserow (optional)
BASEROW_URL=https://api.baserow.io
BASEROW_TOKEN=

# LLM / AI Provider (Google Gemini)
# Get a free API key: https://aistudio.google.com/apikey
LLM_API_KEY=
LLM_MODEL=gemini-2.0-flash
LLM_PROVIDER=google
