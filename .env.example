# ==========================================
# Career-Ops v2 — Environment Configuration
# ==========================================
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# Application
APP_NAME=Career-Ops
APP_VERSION=2.0.0
APP_ENV=development
DEBUG=false

# Database
DATABASE_URL=sqlite:///./data/careerops.db
# PostgreSQL (production)
# DATABASE_URL=postgresql://careerops:changeme@localhost:5432/careerops
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
CORS_ALLOW_CREDENTIALS=true

# JWT Security
SECRET_KEY=change-this-secret-key-to-a-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Baserow (optional)
BASEROW_URL=https://api.baserow.io
BASEROW_TOKEN=

# LLM / AI Provider (Google Gemini)
# Get a free API key: https://aistudio.google.com/apikey
LLM_API_KEY=
LLM_MODEL=gemini-2.0-flash
LLM_PROVIDER=google

# ======================================
# n8n (Workflow Automation)
# ======================================

# n8n host/domain (for webhook callbacks)
N8N_HOST=localhost:5678

# Encryption key for n8n credentials (generate with: openssl rand -hex 32)
N8N_ENCRYPTION_KEY=your-n8n-encryption-key-32-bytes-hex


# Enable n8n webhook triggers (set to true to send events to n8n)
N8N_ENABLED=false

# n8n webhook base URL (internal Docker network — use n8n:5678)
N8N_WEBHOOK_BASE_URL=http://n8n:5678

# ======================================
# SMTP / Email (Auto-Apply Engine)
# ======================================

# SMTP host (Gmail: smtp.gmail.com, SendGrid: smtp.sendgrid.net)
SMTP_HOST=smtp.gmail.com

# SMTP port (Gmail: 587, SendGrid: 587)
SMTP_PORT=587

# SMTP credentials
SMTP_USER=
SMTP_PASSWORD=

# From email address
SMTP_FROM_EMAIL=careerops@example.com
SMTP_FROM_NAME=Career-Ops Auto-Apply

# Use TLS (true for 587, false for 465)
SMTP_TLS=true

# Set to true to enable sending real emails
SMTP_ENABLED=false

# ======================================
# Auto-Apply Engine
# ======================================

# Maximum applications per day
AUTO_APPLY_DAILY_LIMIT=20

# Days after interview to send follow-up
AUTO_APPLY_INTERVIEW_FOLLOWUP_DAYS=3
