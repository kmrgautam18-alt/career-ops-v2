# ==========================================
# Career-Ops v2 — Production Environment
# ==========================================
# Copy this file to .env and fill in real values.
#   cp .env.example .env
# ==========================================

# ---------- Application ----------
APP_NAME=Career-Ops
APP_VERSION=0.1.0
APP_ENV=production
DEBUG=false

# ---------- Database (PostgreSQL) ----------
# For local dev with SQLite, uncomment:
# DATABASE_URL=sqlite:///data/careerops.db
DATABASE_URL=postgresql://careerops:your-strong-password@postgres:5432/careerops

POSTGRES_DB=careerops
POSTGRES_USER=careerops
POSTGRES_PASSWORD=your-strong-password
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# ---------- CORS ----------
# Comma-separated list of allowed origins (no trailing slashes)
CORS_ORIGINS=http://localhost:3000,https://yourdomain.com
CORS_ALLOW_CREDENTIALS=true

# ---------- JWT Security ----------
# Generate with: openssl rand -hex 64
SECRET_KEY=change-this-to-a-secure-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
