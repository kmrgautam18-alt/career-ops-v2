{
  "title": "Career-Ops v2 — Production Overview",
  "uid": "careerops-overview",
  "version": 1,
  "schemaVersion": 39,
  "tags": ["careerops", "production"],
  "timezone": "browser",
  "editable": true,
  "refresh": "30s",
  "panels": [
    {
      "title": "API Request Rate",
      "type": "stat",
      "gridPos": { "h": 8, "w": 4, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "rate(careerops_http_requests_total[5m])",
          "legendFormat": "req/s"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "palette-classic" }
        }
      }
    },
    {
      "title": "Active Requests",
      "type": "stat",
      "gridPos": { "h": 8, "w": 4, "x": 4, "y": 0 },
      "targets": [
        {
          "expr": "careerops_http_active_requests",
          "legendFormat": "active"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 50 }
            ]
          }
        }
      }
    },
    {
      "title": "App Uptime",
      "type": "stat",
      "gridPos": { "h": 8, "w": 4, "x": 8, "y": 0 },
      "targets": [
        {
          "expr": "careerops_up",
          "legendFormat": "up"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds",
            "thresholds": {
              "steps": [
                { "color": "red", "value": null },
                { "color": "green", "value": 1 }
              ]
            }
          }
        }
      }
    },
    {
      "title": "API Response Duration (p95)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(careerops_http_request_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.50, sum(rate(careerops_http_request_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p50"
        }
      ],
      "options": {
        "legend": { "calcs": [], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "palette-classic" }
        }
      }
    },
    {
      "title": "HTTP Status Codes",
      "type": "bargauge",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "sum(rate(careerops_http_requests_total{status=~\"2..\"}[5m]))",
          "legendFormat": "2xx Success"
        },
        {
          "expr": "sum(rate(careerops_http_requests_total{status=~\"4..\"}[5m]))",
          "legendFormat": "4xx Client Error"
        },
        {
          "expr": "sum(rate(careerops_http_requests_total{status=~\"5..\"}[5m]))",
          "legendFormat": "5xx Server Error"
        }
      ],
      "options": {
        "orientation": "horizontal",
        "displayMode": "gradient",
        "showUnfilled": true
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          }
        }
      }
    },
    {
      "title": "AI Request Volume",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "rate(careerops_ai_requests_total[5m])",
          "legendFormat": "{{feature}}"
        }
      ],
      "options": {
        "legend": { "calcs": [], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" }
        }
      }
    },
    {
      "title": "AI Request Duration",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "targets": [
        {
          "expr": "rate(careerops_ai_request_duration_seconds_sum[5m]) / rate(careerops_ai_request_duration_seconds_count[5m])",
          "legendFormat": "avg {{feature}}"
        }
      ],
      "options": {
        "legend": { "calcs": [], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "palette-classic" }
        }
      }
    },
    {
      "title": "Business Metrics — Users",
      "type": "stat",
      "gridPos": { "h": 6, "w": 3, "x": 0, "y": 24 },
      "targets": [
        {
          "expr": "careerops_users_total",
          "legendFormat": "users"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      }
    },
    {
      "title": "Business Metrics — Jobs",
      "type": "stat",
      "gridPos": { "h": 6, "w": 3, "x": 3, "y": 24 },
      "targets": [
        {
          "expr": "careerops_jobs_total",
          "legendFormat": "jobs"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      }
    },
    {
      "title": "Business Metrics — Applications",
      "type": "stat",
      "gridPos": { "h": 6, "w": 3, "x": 6, "y": 24 },
      "targets": [
        {
          "expr": "careerops_applications_total",
          "legendFormat": "apps"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      }
    },
    {
      "title": "Business Metrics — Resumes",
      "type": "stat",
      "gridPos": { "h": 6, "w": 3, "x": 9, "y": 24 },
      "targets": [
        {
          "expr": "careerops_resumes_total",
          "legendFormat": "resumes"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      }
    },
    {
      "title": "Applications by Status",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 30 },
      "targets": [
        {
          "expr": "careerops_applications_by_status",
          "legendFormat": "{{status}}"
        }
      ],
      "options": {
        "legend": { "displayMode": "table", "placement": "right" },
        "pieType": "pie",
        "reduceOptions": { "calcs": ["sum"] },
        "tooltip": { "mode": "single" }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" }
        }
      }
    },
    {
      "title": "DB Query Duration (p95)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 30 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(careerops_db_query_duration_seconds_bucket[5m])) by (le, operation))",
          "legendFormat": "{{operation}}"
        }
      ],
      "options": {
        "legend": { "calcs": [], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "palette-classic" }
        }
      }
    }
  ]
}
